{
  "editor.formatOnSave": true,
  "editor.tabSize": 2,
  "[shellscript]": {
    "editor.defaultFormatter": "mads-hartmann.bash-ide-vscode",
    "editor.tabSize": 2,
    "editor.formatOnSave": true
  },
  "shellformat.effectLanguages": [
    "bash",
    "shell",
    "shellscript",
    "dockerfile",
    "dotenv",
    "ignore",
    "gitignore",
    "properties"
  ],
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "cSpell.words": [
    "documentclass",
    "esbenp",
    "foxundermoon",
    "mktemp",
    "nvmrc",
    "opencode",
    "OPENCODEVERSION",
    "pdflatex",
    "pipefail",
    "shellcheck",
    "shfmt",
    "texlive"
  ]
}
